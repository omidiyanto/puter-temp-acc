{
  "name": "puter-temp-account",
  "version": "1.1.0",
  "private": true,
  "description": "Automate creation of Puter.com temporary (guest) accounts with patchright (stealth Playwright) that bypasses Cloudflare Turnstile",
  "scripts": {
    "create": "node create_temp_account.js",
    "create:chrome": "node create_temp_account.js --channel=chrome",
    "create:hidden": "node create_temp_account_hidden.js",
    "create:hidden:chrome": "node create_temp_account_hidden.js --channel=chrome",
    "install:chromium": "patchright install chromium",
    "install:chrome": "patchright install chrome",
    "postinstall": "patchright install chromium"
  },
  "dependencies": {
    "patchright": "^1.55.0"
  }
}
